<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List ──────────────────────────────────────────────────────────── -->
    <record id="view_hospital_doctor_list" model="ir.ui.view">
        <field name="name">hospital.doctor.list</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <list string="Doctors"
                  decoration-success="state == 'active'"
                  decoration-warning="state == 'on_leave'"
                  decoration-muted="state == 'inactive'">
                <field name="photo" widget="image" options="{'size': [32,32]}" optional="show"/>
                <field name="ref" string="ID"/>
                <field name="name"/>
                <field name="specialisation" optional="show"/>
                <field name="degree" optional="show"/>
                <field name="phone" optional="show"/>
                <field name="appointment_count" string="Appts."/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'on_leave'"
                       decoration-muted="state == 'inactive'"/>
            </list>
        </field>
    </record>

    <!-- ── Form ──────────────────────────────────────────────────────────── -->
    <record id="view_hospital_doctor_form" model="ir.ui.view">
        <field name="name">hospital.doctor.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <header>
                    <button name="action_set_active"   string="Set Active"
                            type="object" class="btn-success"
                            invisible="state == 'active'"/>
                    <button name="action_set_on_leave" string="On Leave"
                            type="object" class="btn-warning"
                            invisible="state == 'on_leave'"/>
                    <button name="action_set_inactive" string="Deactivate"
                            type="object"
                            invisible="state == 'inactive'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,on_leave,inactive"/>
                </header>
                <sheet>
                    <!-- Smart button -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_appointments"
                                type="object" class="oe_stat_button" icon="fa-calendar">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="appointment_count"/>
                                </span>
                                <span class="o_stat_text">Appointments</span>
                            </div>
                        </button>
                    </div>

                    <!-- Photo + Title -->
                    <field name="photo" widget="image" class="oe_avatar"
                           options="{'preview_image': 'photo'}"/>
                    <div class="oe_title">
                        <label for="ref" class="text-muted small"/>
                        <div><field name="ref" readonly="1" class="text-muted small"/></div>
                        <h1><field name="name" placeholder="Doctor full name…"/></h1>
                        <h4 class="text-muted">
                            <field name="specialisation" placeholder="Specialisation…"/>
                        </h4>
                    </div>

                    <group>
                        <group string="Professional Details">
                            <field name="degree"/>
                            <field name="license_no"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Contact">
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Schedule tab -->
                        <page string="Schedule" name="schedule">
                            <group>
                                <group string="Available Days">
                                    <field name="available_mon" widget="boolean_toggle"/>
                                    <field name="available_tue" widget="boolean_toggle"/>
                                    <field name="available_wed" widget="boolean_toggle"/>
                                    <field name="available_thu" widget="boolean_toggle"/>
                                    <field name="available_fri" widget="boolean_toggle"/>
                                    <field name="available_sat" widget="boolean_toggle"/>
                                    <field name="available_sun" widget="boolean_toggle"/>
                                </group>
                                <group string="Consulting Hours">
                                    <field name="consultation_from"
                                           widget="float_time" string="From"/>
                                    <field name="consultation_to"
                                           widget="float_time" string="To"/>
                                    <field name="consultation_duration"
                                           string="Slot (minutes)"/>
                                </group>
                            </group>
                        </page>

                        <!-- Notes tab -->
                        <page string="Notes" name="notes">
                            <field name="note" nolabel="1"
                                   placeholder="Internal notes about this doctor…"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Kanban ─────────────────────────────────────────────────────────── -->
    <record id="view_hospital_doctor_kanban" model="ir.ui.view">
        <field name="name">hospital.doctor.kanban</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <kanban quick_create="false">
                <field name="name"/>
                <field name="specialisation"/>
                <field name="state"/>
                <field name="photo"/>
                <field name="appointment_count"/>
                <field name="phone"/>
                <templates>
                    <t t-name="card">
                        <aside t-if="record.photo.raw_value">
                            <field name="photo" widget="image" class="o_image_64_cover"/>
                        </aside>
                        <main>
                            <div class="fw-bold fs-5">
                                <field name="name"/>
                            </div>
                            <div class="text-muted small">
                                <field name="specialisation"/>
                            </div>
                            <div class="text-muted small" invisible="not phone">
                                <i class="fa fa-phone me-1"/>
                                <field name="phone"/>
                            </div>
                        </main>
                        <footer>
                            <span class="text-muted small">
                                <i class="fa fa-calendar me-1"/>
                                <field name="appointment_count"/> appts
                            </span>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'active'"
                                   decoration-warning="state == 'on_leave'"
                                   decoration-muted="state == 'inactive'"
                                   class="ms-auto"/>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Search ─────────────────────────────────────────────────────────── -->
    <record id="view_hospital_doctor_search" model="ir.ui.view">
        <field name="name">hospital.doctor.search</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <search string="Search Doctors">
                <field name="name"/>
                <field name="specialisation"/>
                <separator/>
                <filter name="active"   string="Active"   domain="[('state','=','active')]"/>
                <filter name="on_leave" string="On Leave" domain="[('state','=','on_leave')]"/>
                <group>
                    <filter name="group_spec"  string="Specialisation"
                            context="{'group_by':'specialisation'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->
    <record id="action_hospital_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_hospital_doctor_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add the first doctor</p>
            <p>Create doctor profiles with specialisations, schedules and linked Odoo users.</p>
        </field>
    </record>

</odoo>
