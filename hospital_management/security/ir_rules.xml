<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">

    <!-- ══════════════════════════════════════════════════════════════════════
         GLOBAL MULTI-COMPANY RULES
         Applied to all users — filter records to user's active companies.
    ══════════════════════════════════════════════════════════════════════════ -->

    <record id="rule_hospital_patient_company" model="ir.rule">
        <field name="name">Hospital Patient: Multi-company</field>
        <field name="model_id" ref="model_hospital_patient"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
        <field name="global" eval="True"/>
    </record>

    <record id="rule_hospital_appointment_company" model="ir.rule">
        <field name="name">Hospital Appointment: Multi-company</field>
        <field name="model_id" ref="model_hospital_appointment"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
        <field name="global" eval="True"/>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         MANAGER OVERRIDE
         Managers see ALL records regardless of company (overrides global rule).
         Odoo applies group rules as OR with the global rule for that group.
    ══════════════════════════════════════════════════════════════════════════ -->

    <record id="rule_hospital_patient_manager_all" model="ir.rule">
        <field name="name">Hospital Patient: Manager sees all</field>
        <field name="model_id" ref="model_hospital_patient"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hospital_management.group_hospital_manager'))]"/>
    </record>

    <record id="rule_hospital_appointment_manager_all" model="ir.rule">
        <field name="name">Hospital Appointment: Manager sees all</field>
        <field name="model_id" ref="model_hospital_appointment"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hospital_management.group_hospital_manager'))]"/>
    </record>

</data>
</odoo>
