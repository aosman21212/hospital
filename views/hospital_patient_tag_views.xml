<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List ──────────────────────────────────────────────────────────── -->
    <record id="view_hospital_patient_tag_list" model="ir.ui.view">
        <field name="name">hospital.patient.tag.list</field>
        <field name="model">hospital.patient.tag</field>
        <field name="arch" type="xml">
            <list string="Patient Tags" editable="top">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- ── Form ──────────────────────────────────────────────────────────── -->
    <record id="view_hospital_patient_tag_form" model="ir.ui.view">
        <field name="name">hospital.patient.tag.form</field>
        <field name="model">hospital.patient.tag</field>
        <field name="arch" type="xml">
            <form string="Patient Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────────── -->
    <record id="action_hospital_patient_tag" model="ir.actions.act_window">
        <field name="name">Patient Tags</field>
        <field name="res_model">hospital.patient.tag</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
